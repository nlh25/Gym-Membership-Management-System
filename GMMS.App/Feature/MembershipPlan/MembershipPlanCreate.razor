@using MudBlazor

<MudDialog MaxWidth="MaxWidth.Small" FullWidth="true">
    <TitleContent>
        <MudText Typo="Typo.h6">
            <MudIcon Icon="@Icons.Material.Filled.AddCard" Class="mr-3" Color="Color.Primary" /> Create Membership Plan
        </MudText>
    </TitleContent>

    <DialogContent>
        @if (!string.IsNullOrEmpty(errorMessage))
        {
            <MudAlert Severity="Severity.Error" Class="mb-4">@errorMessage</MudAlert>
        }

        <MudTextField @bind-Value="request.PlanCode"
                      @oninput="OnPlanCodeChanged"
                      Label="Plan Code"
                      Variant="Variant.Outlined"
                      Required="true"
                      RequiredError="Plan Code is required."
                      MaxLength="50"
                      Class="mb-3"
                      HelperText="Uppercase letters, numbers, and hyphens only (max 50 chars)" />

        <MudTextField @bind-Value="request.PlanName"
                      @oninput="OnPlanNameChanged"
                      Label="Plan Name"
                      Variant="Variant.Outlined"
                      Required="true"
                      RequiredError="Plan Name is required."
                      MaxLength="100"
                      Class="mb-3" />

        <MudTextField @bind-Value="request.Description"
                      @oninput="OnDescriptionChanged"
                      Label="Description"
                      Variant="Variant.Outlined"
                      MultiLine="true"
                      Rows="3"
                      MaxLength="500"
                      Class="mb-3"
                      HelperText="Max 500 characters" />

        <MudNumericField @bind-Value="request.DurationDays"
                         T="int"
                         Label="Duration (Days)"
                         Variant="Variant.Outlined"
                         Required="true"
                         RequiredError="Duration is required."
                         Min="1"
                         Max="3650"
                         Class="mb-3"
                         HelperText="1-3650 days (max 10 years)" />

        <MudNumericField @bind-Value="request.Price"
                         T="decimal"
                         Label="Price"
                         Variant="Variant.Outlined"
                         Required="true"
                         RequiredError="Price is required."
                         Min="0.01m"
                         Max="1000000"
                         Step="0.01m"
                         Class="mb-3" />
    </DialogContent>

    <DialogActions>
        <MudButton OnClick="Cancel" Variant="Variant.Text" Class="mr-2">Cancel</MudButton>
        <MudButton OnClick="Save"
                   Variant="Variant.Filled"
                   Color="Color.Primary"
                   StartIcon="@Icons.Material.Filled.Save"
                   Disabled="@isSaving">
            @if (isSaving)
            {
                <MudProgressCircular Size="Size.Small" Indeterminate="true" Class="mr-2" />
            }
            Save
        </MudButton>
    </DialogActions>
</MudDialog>