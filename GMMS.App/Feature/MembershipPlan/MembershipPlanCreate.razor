@page "/membershipplan-create"
@using Microsoft.AspNetCore.Components.Forms

<h3>Create Membership Plan</h3>

@if (!string.IsNullOrEmpty(errorMessage))
{
    <div class="alert alert-danger">@errorMessage</div>
}

<div class="row">
    <div class="col-md-6">
        <EditForm Model="request" OnSubmit="Save">
            <div class="mb-3">
                <label for="planCode" class="form-label">Plan Code</label>
                <InputText id="planCode" class="form-control" @bind-Value="request.PlanCode" />
            </div>
            <div class="mb-3">
                <label for="planName" class="form-label">Plan Name</label>
                <InputText id="planName" class="form-control" @bind-Value="request.PlanName" />
            </div>
            <div class="mb-3">
                <label for="price" class="form-label">Price</label>
                <InputNumber id="price" class="form-control" @bind-Value="request.Price" />
            </div>
            <div class="mb-3">
                <label for="durationDays" class="form-label">Duration (Days)</label>
                <InputNumber id="durationDays" class="form-control" @bind-Value="request.DurationDays" />
            </div>
            <div class="mb-3">
                <label for="description" class="form-label">Description</label>
                <InputText id="description" class="form-control" @bind-Value="request.Description" />
            </div>
            <button type="submit" class="btn btn-primary" disabled="@isLoading">
                @if (isLoading)
                {
                    <span class="spinner-border spinner-border-sm me-1"></span>
                }
                Save
            </button>
            <a class="btn btn-secondary ms-2" href="membershipplan-list">Cancel</a>
        </EditForm>
    </div>
</div>
