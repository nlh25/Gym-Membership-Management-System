@page "/membershipplan-list"
@using GMMS.Domain.Features.MemberShipPlan.Models

<h3>Membership Plan List</h3>

@if (isLoading)
{
    <div class="d-flex justify-content-center">
        <div class="spinner-border" role="status">
            <span class="visually-hidden">Loading...</span>
        </div>
    </div>
}
else if (errorMessage is not null)
{
    <div class="alert alert-danger">@errorMessage</div>
}
else
{
    <div class="d-flex justify-content-between align-items-center mb-3">
        <span>Total: <strong>@totalCount</strong> plans</span>
        <a class="btn btn-primary" href="membershipplan-create">
            <i class="bi bi-plus-lg"></i> Create Plan
        </a>
    </div>

    @if (plans is not null && plans.Count > 0)
    {
        <div class="table-responsive">
            <table class="table table-striped table-hover">
                <thead class="table-dark">
                    <tr>
                        <th>#</th>
                        <th>Plan Code</th>
                        <th>Plan Name</th>
                        <th>Price</th>
                        <th>Duration (Days)</th>
                        <th>Actions</th>
                    </tr>
                </thead>
                <tbody>
                    @foreach (var p in plans)
                    {
                        <tr>
                            <td>@p.MemberShipPlanId</td>
                            <td>@p.PlanCode</td>
                            <td>@p.PlanName</td>
                            <td>@p.Price.ToString("C2")</td>
                            <td>@p.DurationDays</td>
                            <td>
                                <a class="btn btn-sm btn-outline-primary me-1" href="membershipplan-edit/@p.MemberShipPlanId">
                                    <i class="bi bi-pencil"></i>
                                </a>
                                <a class="btn btn-sm btn-outline-danger" href="membershipplan-delete/@p.MemberShipPlanId">
                                    <i class="bi bi-trash"></i>
                                </a>
                            </td>
                        </tr>
                    }
                </tbody>
            </table>
        </div>
    }
    else
    {
        <div class="alert alert-info">No plans found.</div>
    }
}
