@using MudBlazor

<MudDialog MaxWidth="MaxWidth.Medium" FullWidth="true">
    <TitleContent>
        <MudText Typo="Typo.h6">
            <MudIcon Icon="@Icons.Material.Filled.Info" Class="mr-3" Color="Color.Info" /> Membership Plan Details
        </MudText>
    </TitleContent>

    <DialogContent>
        @if (isLoading)
        {
            <div class="d-flex justify-center pa-6">
                <MudProgressCircular Indeterminate="true" Size="Size.Large" />
            </div>
        }
        else if (!string.IsNullOrEmpty(errorMessage))
        {
            <MudAlert Severity="Severity.Error">@errorMessage</MudAlert>
        }
        else if (plan is not null)
        {
            <div class="pa-4">
                <MudCard Class="mb-4">
                    <MudCardContent>
                        <div class="d-flex align-center mb-3">
                            <MudIcon Icon="@(plan.IsActive ? Icons.Material.Filled.CheckCircle : Icons.Material.Filled.Cancel)" Color="@(plan.IsActive ? Color.Success : Color.Error)" Size="Size.Large" Class="mr-3" />
                            <div>
                                <MudText Typo="Typo.h6">@plan.PlanName</MudText>
                                <MudText Typo="Typo.body2" Color="Color.Secondary">@plan.PlanCode</MudText>
                            </div>
                        </div>
                        <MudDivider Class="mb-3" />
                        <div class="d-flex flex-wrap gap-4">
                            <MudText Typo="Typo.body1"><MudText Typo="Typo.body2" Color="Color.Secondary">Price: </MudText>@plan.Price.ToString("C2")</MudText>
                            <MudText Typo="Typo.body1"><MudText Typo="Typo.body2" Color="Color.Secondary">Duration: </MudText>@plan.DurationDays days</MudText>
                            <MudText Typo="Typo.body1"><MudText Typo="Typo.body2" Color="Color.Secondary">Status: </MudText>
                                <MudChip T="string" Color="@(plan.IsActive ? Color.Success : Color.Default)" Size="Size.Small">
                                    @(plan.IsActive ? "Active" : "Inactive")
                                </MudChip>
                            </MudText>
                        </div>
                    </MudCardContent>
                </MudCard>

                <MudCard>
                    <MudCardHeader>
                        <MudText Typo="Typo.subtitle2">Description</MudText>
                    </MudCardHeader>
                    <MudCardContent>
                        <MudText Typo="Typo.body1" Class="@(string.IsNullOrWhiteSpace(plan.Description) ? "mud-text-secondary" : "")">
                            @(string.IsNullOrWhiteSpace(plan.Description) ? "No description provided." : plan.Description)
                        </MudText>
                    </MudCardContent>
                </MudCard>

                <MudCard>
                    <MudCardHeader>
                        <MudText Typo="Typo.subtitle2">Timestamps</MudText>
                    </MudCardHeader>
                    <MudCardContent>
                        <div class="d-flex flex-wrap gap-4">
                            <MudText Typo="Typo.body1"><MudText Typo="Typo.body2" Color="Color.Secondary">Created: </MudText>@plan.CreatedAt.ToString("yyyy-MM-dd HH:mm")</MudText>
                            <MudText Typo="Typo.body1"><MudText Typo="Typo.body2" Color="Color.Secondary">Updated: </MudText>@(plan.UpdatedAt?.ToString("yyyy-MM-dd HH:mm") ?? "Never")</MudText>
                        </div>
                    </MudCardContent>
                </MudCard>
            </div>
        }
    </DialogContent>

    <DialogActions>
        <MudButton OnClick="Cancel" Variant="Variant.Filled" Color="Color.Primary">Close</MudButton>
    </DialogActions>
</MudDialog>