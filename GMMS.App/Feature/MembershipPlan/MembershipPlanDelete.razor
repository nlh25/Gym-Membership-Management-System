@page "/membershipplan-delete/{id:int}"

<h3>Delete Membership Plan</h3>

@if (errorMessage is not null)
{
    <div class="alert alert-danger">@errorMessage</div>
}

@if (isLoading)
{
    <div class="d-flex justify-content-center">
        <div class="spinner-border" role="status">
            <span class="visually-hidden">Loading...</span>
        </div>
    </div>
}
else if (plan is not null)
{
    <div class="card" style="max-width: 500px;">
        <div class="card-body">
            <h5 class="card-title">@plan.PlanName</h5>
            <p class="card-text">
                <strong>Plan Code:</strong> @plan.PlanCode<br />
                <strong>Description:</strong> @plan.Description<br />
                <strong>Duration:</strong> @plan.DurationDays days<br />
                <strong>Price:</strong> @plan.Price.ToString("C2")
            </p>
            <div class="alert alert-warning">
                Are you sure you want to delete this plan?
            </div>
            <EditForm Model="this" FormName="delete-plan-form" OnValidSubmit="ConfirmDelete">
                <button type="submit" class="btn btn-danger me-2" disabled="@isDeleting">
                    @if (isDeleting)
                    {
                        <span class="spinner-border spinner-border-sm me-1"></span>
                    }
                    Yes, Delete
                </button>
                <a class="btn btn-secondary" href="membershipplan-list">Cancel</a>
            </EditForm>
        </div>
    </div>
}
