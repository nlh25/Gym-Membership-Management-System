@page "/payment-list"

<MudContainer MaxWidth="MaxWidth.Large">
    <MudPaper Class="pa-6" Elevation="2">
        <MudText Typo="Typo.h4" Class="mb-4">Payment List</MudText>

        <div class="d-flex flex-wrap justify-space-between align-start mb-4" style="gap: 16px;">
            <MudTextField @bind-Value="searchTerm" Placeholder="Search..." Variant="Variant.Outlined" Adornment="Adornment.Start" AdornmentIcon="@Icons.Material.Filled.Search" Clearable="true" Immediate="true" Style="width: 100%; max-width: 380px;" />

            <div class="d-flex flex-wrap align-center" style="gap: 12px;">
                <MudText Typo="Typo.body2" Class="d-flex align-center">
                    Total: <strong class="ml-2 mud-primary-text">@totalCount</strong>
                </MudText>
                <MudButton Variant="Variant.Filled" Color="Color.Primary" OnClick="OpenCreateDialog" StartIcon="@Icons.Material.Filled.Add" Size="Size.Small">
                    Create Payment
                </MudButton>
            </div>
        </div>

        @if (isLoading)
        {
            <div class="d-flex justify-center pa-12">
                <MudProgressCircular Indeterminate="true" Size="Size.Large" />
            </div>
        }
        else if (errorMessage is not null)
        {
            <MudAlert Severity="Severity.Error" Class="mt-4">@errorMessage</MudAlert>
        }
        else if (payments is not null && payments.Count > 0)
        {
            <MudTable Items="payments" Dense="true" Hover="true" Striped="true" Breakpoint="Breakpoint.Sm" Elevation="1" Class="rounded">
                <HeaderContent>
                    <MudTh>#</MudTh>
                    <MudTh>Payment ID</MudTh>
                    <MudTh>Payment Method</MudTh>
                    <MudTh>Amount</MudTh>
                    <MudTh>Status</MudTh>
                    <MudTh>Created At</MudTh>
                    <MudTh Style="text-align: center;">Actions</MudTh>
                </HeaderContent>
                <RowTemplate>
                    <MudTd DataLabel="#">@context.PaymentId</MudTd>
                    <MudTd DataLabel="Payment ID">@context.PaymentId</MudTd>
                    <MudTd DataLabel="Payment Method">@context.PaymentMethodName</MudTd>
                    <MudTd DataLabel="Amount">@context.Amount.ToString("C2")</MudTd>
                    <MudTd DataLabel="Status">
                        <MudChip T="string" Color="@GetStatusColor(context.Status)" Size="Size.Small">@context.Status</MudChip>
                    </MudTd>
                    <MudTd DataLabel="Created At">@context.CreatedAt.ToString("yyyy-MM-dd HH:mm")</MudTd>
                    <MudTd DataLabel="Actions" Style="text-align: center;">
                        <MudIconButton Icon="@Icons.Material.Filled.Visibility" Color="Color.Info" OnClick="@(() => OpenDetailDialog(context.PaymentId))" Size="Size.Small" />
                    </MudTd>
                </RowTemplate>
            </MudTable>

            <div class="d-flex flex-column align-center mt-6">
                <MudPagination BoundaryCount="1" MiddleCount="1" Count="@totalPages" Selected="@_pageSelected" SelectedChanged="PageChanged" />
            </div>
        }
        else
        {
            <MudAlert Severity="Severity.Info" Class="mt-4">No payments found.</MudAlert>
        }
    </MudPaper>
</MudContainer>