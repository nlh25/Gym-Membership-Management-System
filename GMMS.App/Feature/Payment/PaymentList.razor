@page "/payment-list"

<h3>Payment List</h3>

@if (isLoading)
{
    <div class="d-flex justify-content-center">
        <div class="spinner-border" role="status">
            <span class="visually-hidden">Loading...</span>
        </div>
    </div>
}
else if (errorMessage is not null)
{
    <div class="alert alert-danger">@errorMessage</div>
}
else if (payments is null || payments.Count == 0)
{
    <div class="alert alert-info">
        No payments found.
        <a class="btn btn-primary btn-sm ms-3" href="payment-create">Create one</a>
    </div>
}
else
{
    <div class="d-flex justify-content-between align-items-center mb-3">
        <span>Total: <strong>@totalCount</strong> payments</span>
        <a class="btn btn-primary" href="payment-create">
            <i class="bi bi-plus-lg"></i> Create Payment
        </a>
    </div>

    <div class="table-responsive">
        <table class="table table-striped table-hover">
            <thead class="table-dark">
                <tr>
                    <th scope="col">#</th>
                    <th scope="col">Membership ID</th>
                    <th scope="col">Payment Method</th>
                    <th scope="col">Amount</th>
                    <th scope="col">Status</th>
                    <th scope="col">Created At</th>
                </tr>
            </thead>
            <tbody>
                @foreach (var p in payments)
                {
                    <tr>
                        <td>@p.PaymentId</td>
                        <td>@p.MembershipId</td>
                        <td>@p.PaymentMethodName</td>
                        <td>@p.Amount.ToString("C")</td>
                        <td>@p.Status</td>
                        <td>@p.CreatedAt.ToString("yyyy-MM-dd HH:mm")</td>
                    </tr>
                }
            </tbody>
        </table>
    </div>

    <nav>
        <ul class="pagination justify-content-center">
            <li class="page-item @(pageNumber <= 1 ? "disabled" : "")">
                @if (pageNumber > 1)
                {
                    <a class="page-link" href="/payment-list?page=@(pageNumber - 1)">Previous</a>
                }
                else
                {
                    <span class="page-link">Previous</span>
                }
            </li>
            <li class="page-item disabled">
                <span class="page-link">Page @pageNumber of @totalPages</span>
            </li>
            <li class="page-item @(pageNumber >= totalPages ? "disabled" : "")">
                @if (pageNumber < totalPages)
                {
                    <a class="page-link" href="/payment-list?page=@(pageNumber + 1)">Next</a>
                }
                else
                {
                    <span class="page-link">Next</span>
                }
            </li>
        </ul>
    </nav>
}
