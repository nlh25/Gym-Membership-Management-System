@page "/payment-list"
@using GMMS.Domain.Features.Payment.Models

<h3>Payment List</h3>

@if (isLoading)
{
    <div class="d-flex justify-content-center">
        <div class="spinner-border" role="status">
            <span class="visually-hidden">Loading...</span>
        </div>
    </div>
}
else if (errorMessage is not null)
{
    <div class="alert alert-danger">@errorMessage</div>
}
else
{
    <div class="d-flex justify-content-between align-items-center mb-3">
        <span>Total: <strong>@totalCount</strong> payments</span>
        <a class="btn btn-primary" href="payment-create">
            <i class="bi bi-plus-lg"></i> Create Payment
        </a>
    </div>

    @if (payments is not null && payments.Count > 0)
    {
        <div class="table-responsive">
            <table class="table table-striped table-hover">
                <thead class="table-dark">
                    <tr>
                        <th>#</th>
                        <th>Payment ID</th>
                        <th>Payment Method</th>
                        <th>Amount</th>
                        <th>Status</th>
                        <th>Created At</th>
                    </tr>
                </thead>
                <tbody>
                    @foreach (var p in payments)
                    {
                        <tr>
                            <td>@p.PaymentId</td>
                            <td>@p.PaymentId</td>
                            <td>@p.PaymentMethodName</td>
                            <td>@p.Amount.ToString("C2")</td>
                            <td>@p.Status</td>
                            <td>@p.CreatedAt.ToString("yyyy-MM-dd HH:mm")</td>
                        </tr>
                    }
                </tbody>
            </table>
        </div>
    }
    else
    {
        <div class="alert alert-info">No payments found.</div>
    }
}
