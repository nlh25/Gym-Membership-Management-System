@page "/member-delete/{id:int}"

<h3>Delete Member</h3>

@if (errorMessage is not null)
{
    <div class="alert alert-danger">@errorMessage</div>
}

@if (isLoading)
{
    <div class="d-flex justify-content-center">
        <div class="spinner-border" role="status">
            <span class="visually-hidden">Loading...</span>
        </div>
    </div>
}
else if (member is not null)
{
    <div class="card" style="max-width: 400px;">
        <div class="card-body">
            <h5 class="card-title">@member.Name</h5>
            <p class="card-text">
                <strong>Code:</strong> @member.MemberCode<br />
                <strong>Created:</strong> @member.CreatedAt.ToString("yyyy-MM-dd HH:mm")
            </p>
            <div class="alert alert-warning">
                Are you sure you want to delete this member?
            </div>
            <EditForm Model="this" FormName="delete-member-form" OnValidSubmit="ConfirmDelete">
                <button type="submit" class="btn btn-danger me-2" disabled="@isDeleting">
                    @if (isDeleting)
                    {
                        <span class="spinner-border spinner-border-sm me-1"></span>
                    }
                    Yes, Delete
                </button>
                <a class="btn btn-secondary" href="member-list">Cancel</a>
            </EditForm>
        </div>
    </div>
}
