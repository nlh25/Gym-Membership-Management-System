@page "/member-list"

<h3>Member List</h3>

@if (isLoading)
{
    <div class="d-flex justify-content-center">
        <div class="spinner-border" role="status">
            <span class="visually-hidden">Loading...</span>
        </div>
    </div>
}
else if (errorMessage is not null)
{
    <div class="alert alert-danger">@errorMessage</div>
}
else if (members is null || members.Count == 0)
{
    <div class="alert alert-info">
        No members found.
        <a class="btn btn-primary btn-sm ms-3" href="member-create">Create one</a>
    </div>
}
else
{
    <div class="d-flex justify-content-between align-items-center mb-3">
        <span>Total: <strong>@totalCount</strong> members</span>
        <a class="btn btn-primary" href="member-create">
            <i class="bi bi-plus-lg"></i> Create Member
        </a>
    </div>

    <div class="table-responsive">
        <table class="table table-striped table-hover">
            <thead class="table-dark">
                <tr>
                    <th scope="col">#</th>
                    <th scope="col">Member Code</th>
                    <th scope="col">Name</th>
                    <th scope="col">Created At</th>
                    <th scope="col">Actions</th>
                </tr>
            </thead>
            <tbody>
                @foreach (var m in members)
                {
                    <tr>
                        <td>@m.MemberId</td>
                        <td>@m.MemberCode</td>
                        <td>@m.Name</td>
                        <td>@m.CreatedAt.ToString("yyyy-MM-dd HH:mm")</td>
                        <td>
                            <a class="btn btn-sm btn-outline-info me-1" href="/membership-list?memberId=@m.MemberId" title="View Memberships">
                                <i class="bi bi-eye"></i>
                            </a>
                            <a class="btn btn-sm btn-outline-primary me-1" href="member-edit/@m.MemberId" title="Edit">
                                <i class="bi bi-pencil"></i>
                            </a>
                            <a class="btn btn-sm btn-outline-danger" href="member-delete/@m.MemberId" title="Delete">
                                <i class="bi bi-trash"></i>
                            </a>
                        </td>
                    </tr>
                }
            </tbody>
        </table>
    </div>

    <nav>
        <ul class="pagination justify-content-center">
            <li class="page-item @(pageNumber <= 1 ? "disabled" : "")">
                @if (pageNumber > 1)
                {
                    <a class="page-link" href="/member-list?page=@(pageNumber - 1)">Previous</a>
                }
                else
                {
                    <span class="page-link">Previous</span>
                }
            </li>
            <li class="page-item disabled">
                <span class="page-link">Page @pageNumber of @totalPages</span>
            </li>
            <li class="page-item @(pageNumber >= totalPages ? "disabled" : "")">
                @if (pageNumber < totalPages)
                {
                    <a class="page-link" href="/member-list?page=@(pageNumber + 1)">Next</a>
                }
                else
                {
                    <span class="page-link">Next</span>
                }
            </li>
        </ul>
    </nav>
}
