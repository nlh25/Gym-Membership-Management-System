@page "/member-edit/{id:int}"
@using Microsoft.AspNetCore.Components.Forms

<h3>Edit Member</h3>

@if (!string.IsNullOrEmpty(errorMessage))
{
    <div class="alert alert-danger">@errorMessage</div>
}

@if (isLoading)
{
    <div class="d-flex justify-content-center">
        <div class="spinner-border" role="status">
            <span class="visually-hidden">Loading...</span>
        </div>
    </div>
}
else
{
    <div class="row">
        <div class="col-md-6">
            <EditForm Model="request" OnSubmit="Update">
                <div class="mb-3">
                    <label for="memberCode" class="form-label">Member Code</label>
                    <InputText id="memberCode" class="form-control" @bind-Value="request.MemberCode" />
                </div>
                <div class="mb-3">
                    <label for="name" class="form-label">Name</label>
                    <InputText id="name" class="form-control" @bind-Value="request.Name" />
                </div>
                <button type="submit" class="btn btn-primary">
                    Update
                </button>
                
                <a class="btn btn-secondary ms-2" href="member-list">Cancel</a>
            </EditForm>
        </div>
    </div>
}
