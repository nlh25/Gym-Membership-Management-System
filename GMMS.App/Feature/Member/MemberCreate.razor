@using MudBlazor

<MudDialog>
    <TitleContent>
        <MudText Typo="Typo.h6">
            <MudIcon Icon="@Icons.Material.Filled.PersonAdd" Class="mr-3" /> Create Member
        </MudText>
    </TitleContent>

    <DialogContent>
        @if (!string.IsNullOrEmpty(errorMessage))
        {
            <MudAlert Severity="Severity.Error" Class="mb-4">@errorMessage</MudAlert>
        }

        <MudTextField @bind-Value="request.MemberCode"
                      Label="Member Code"
                      Variant="Variant.Outlined"
                      Required="true"
                      RequiredError="Member Code is required."
                      Class="mb-3" />

        <MudTextField @bind-Value="request.Name"
                      Label="Name"
                      Variant="Variant.Outlined"
                      Required="true"
                      RequiredError="Name is required."
                      Class="mb-3" />
    </DialogContent>

    <DialogActions>
        <MudButton OnClick="Cancel" Variant="Variant.Text">Cancel</MudButton>
        <MudButton OnClick="Save"
                   Variant="Variant.Filled"
                   Color="Color.Primary"
                   Disabled="@isLoading">
            @if (isLoading)
            {
                <MudProgressCircular Size="Size.Small" Indeterminate="true" Class="mr-2" />
            }
            Save
        </MudButton>
    </DialogActions>
</MudDialog>
