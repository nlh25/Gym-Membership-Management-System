@using MudBlazor

<MudDialog MaxWidth="MaxWidth.Small" FullWidth="true">
    <TitleContent>
        <MudText Typo="Typo.h6">
            <MudIcon Icon="@Icons.Material.Filled.AddCard" Class="mr-3" Color="Color.Primary" /> Create Payment Method
        </MudText>
    </TitleContent>

    <DialogContent>
        @if (!string.IsNullOrEmpty(errorMessage))
        {
            <MudAlert Severity="Severity.Error" Class="mb-4">@errorMessage</MudAlert>
        }

        <MudTextField @bind-Value="request.PaymentMethodCode"
                      @oninput="OnCodeChanged"
                      Label="Code"
                      Variant="Variant.Outlined"
                      Required="true"
                      RequiredError="Code is required."
                      MaxLength="50"
                      Class="mb-3"
                      HelperText="Uppercase letters, numbers, and hyphens only (max 50 chars)" />

        <MudTextField @bind-Value="request.Name"
                      @oninput="OnNameChanged"
                      Label="Name"
                      Variant="Variant.Outlined"
                      Required="true"
                      RequiredError="Name is required."
                      MaxLength="100"
                      Class="mb-3"
                      HelperText="Max 100 characters" />

        <MudSwitch @bind-Checked="request.IsActive" T="bool" Label="Active" Color="Color.Primary" Class="mb-3" />
    </DialogContent>

    <DialogActions>
        <MudButton OnClick="Cancel" Variant="Variant.Text" Class="mr-2">Cancel</MudButton>
        <MudButton OnClick="Save"
                   Variant="Variant.Filled"
                   Color="Color.Primary"
                   StartIcon="@Icons.Material.Filled.Save"
                   Disabled="@isSaving">
            @if (isSaving)
            {
                <MudProgressCircular Size="Size.Small" Indeterminate="true" Class="mr-2" />
            }
            Save
        </MudButton>
    </DialogActions>
</MudDialog>