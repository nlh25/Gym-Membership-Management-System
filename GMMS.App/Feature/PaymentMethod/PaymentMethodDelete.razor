@page "/paymentmethod-delete/{id:int}"

<h3>Delete Payment Method</h3>

@if (errorMessage is not null)
{
    <div class="alert alert-danger">@errorMessage</div>
}

@if (isLoading)
{
    <div class="d-flex justify-content-center">
        <div class="spinner-border" role="status">
            <span class="visually-hidden">Loading...</span>
        </div>
    </div>
}
else if (method is not null)
{
    <div class="card" style="max-width: 500px;">
        <div class="card-body">
            <h5 class="card-title">@method.Name</h5>
            <p class="card-text">
                <strong>Code:</strong> @method.PaymentMethodCode<br />
                <strong>Active:</strong> @method.IsActive
            </p>
            <div class="alert alert-warning">
                Are you sure you want to delete this payment method?
            </div>
            <EditForm Model="this" FormName="delete-paymentmethod-form" OnValidSubmit="ConfirmDelete">
                <button type="submit" class="btn btn-danger me-2" disabled="@isDeleting">
                    @if (isDeleting)
                    {
                        <span class="spinner-border spinner-border-sm me-1"></span>
                    }
                    Yes, Delete
                </button>
                <a class="btn btn-secondary" href="paymentmethod-list">Cancel</a>
            </EditForm>
        </div>
    </div>
}
