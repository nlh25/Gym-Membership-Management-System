@page "/paymentmethod-list"

<h3>Payment Method List</h3>

@if (isLoading)
{
    <div class="d-flex justify-content-center">
        <div class="spinner-border" role="status">
            <span class="visually-hidden">Loading...</span>
        </div>
    </div>
}
else if (errorMessage is not null)
{
    <div class="alert alert-danger">@errorMessage</div>
}
else if (methods is null || methods.Count == 0)
{
    <div class="alert alert-info">
        No payment methods found.
        <a class="btn btn-primary btn-sm ms-3" href="paymentmethod-create">Create one</a>
    </div>
}
else
{
    <div class="d-flex justify-content-between align-items-center mb-3">
        <span>Total: <strong>@totalCount</strong> payment methods</span>
        <a class="btn btn-primary" href="paymentmethod-create">
            <i class="bi bi-plus-lg"></i> Create Payment Method
        </a>
    </div>

    <div class="table-responsive">
        <table class="table table-striped table-hover">
            <thead class="table-dark">
                <tr>
                    <th scope="col">#</th>
                    <th scope="col">Code</th>
                    <th scope="col">Name</th>
                    <th scope="col">Active</th>
                    <th scope="col">Created At</th>
                    <th scope="col">Actions</th>
                </tr>
            </thead>
            <tbody>
                @foreach (var m in methods)
                {
                    <tr>
                        <td>@m.PaymentMethodId</td>
                        <td>@m.PaymentMethodCode</td>
                        <td>@m.Name</td>
                        <td>@(m.IsActive ? "Yes" : "No")</td>
                        <td>@m.CreatedAt.ToString("yyyy-MM-dd HH:mm")</td>
                        <td>
                            <a class="btn btn-sm btn-outline-primary me-1" href="paymentmethod-edit/@m.PaymentMethodId" title="Edit">
                                <i class="bi bi-pencil"></i>
                            </a>
                            <a class="btn btn-sm btn-outline-danger" href="paymentmethod-delete/@m.PaymentMethodId" title="Delete">
                                <i class="bi bi-trash"></i>
                            </a>
                        </td>
                    </tr>
                }
            </tbody>
        </table>
    </div>

    <nav>
        <ul class="pagination justify-content-center">
            <li class="page-item @(pageNumber <= 1 ? "disabled" : "")">
                @if (pageNumber > 1)
                {
                    <a class="page-link" href="/paymentmethod-list?page=@(pageNumber - 1)">Previous</a>
                }
                else
                {
                    <span class="page-link">Previous</span>
                }
            </li>
            <li class="page-item disabled">
                <span class="page-link">Page @pageNumber of @totalPages</span>
            </li>
            <li class="page-item @(pageNumber >= totalPages ? "disabled" : "")">
                @if (pageNumber < totalPages)
                {
                    <a class="page-link" href="/paymentmethod-list?page=@(pageNumber + 1)">Next</a>
                }
                else
                {
                    <span class="page-link">Next</span>
                }
            </li>
        </ul>
    </nav>
}
