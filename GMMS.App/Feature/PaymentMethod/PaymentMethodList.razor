@page "/paymentmethod-list"

<h3>Payment Method List</h3>

@if (isLoading)
{
    <div class="d-flex justify-content-center">
        <div class="spinner-border" role="status">
            <span class="visually-hidden">Loading...</span>
        </div>
    </div>
}
else if (errorMessage is not null)
{
    <div class="alert alert-danger">@errorMessage</div>
}
else
{
    <div class="d-flex justify-content-between align-items-center mb-3">
        <span>Total: <strong>@totalCount</strong> payment methods</span>
        <a class="btn btn-primary" href="paymentmethod-create">
            <i class="bi bi-plus-lg"></i> Create Payment Method
        </a>
    </div>

    @if (methods is not null && methods.Count > 0)
    {
        <div class="table-responsive">
            <table class="table table-striped table-hover">
                <thead class="table-dark">
                    <tr>
                        <th>#</th>
                        <th>Payment Method Code</th>
                        <th>Name</th>
                        <th>Active</th>
                        <th>Actions</th>
                    </tr>
                </thead>
                <tbody>
                    @foreach (var pm in methods)
                    {
                        <tr>
                            <td>@pm.PaymentMethodId</td>
                            <td>@pm.PaymentMethodCode</td>
                            <td>@pm.Name</td>
                            <td>@pm.IsActive</td>
                            <td>
                                <a class="btn btn-sm btn-outline-primary me-1" href="paymentmethod-edit/@pm.PaymentMethodId">
                                    <i class="bi bi-pencil"></i>
                                </a>
                                <a class="btn btn-sm btn-outline-danger" href="paymentmethod-delete/@pm.PaymentMethodId">
                                    <i class="bi bi-trash"></i>
                                </a>
                            </td>
                        </tr>
                    }
                </tbody>
            </table>
        </div>
    }
    else
    {
        <div class="alert alert-info">No payment methods found.</div>
    }
}
