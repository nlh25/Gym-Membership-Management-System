@page "/membership-delete/{id:int}"

<h3>Delete Membership</h3>

@if (errorMessage is not null)
{
    <div class="alert alert-danger">@errorMessage</div>
}

@if (isLoading)
{
    <div class="d-flex justify-content-center">
        <div class="spinner-border" role="status">
            <span class="visually-hidden">Loading...</span>
        </div>
    </div>
}
else if (membership is not null)
{
    <div class="card" style="max-width: 400px;">
        <div class="card-body">
            <h5 class="card-title">@membership.MemberName - @membership.PlanName</h5>
            <p class="card-text">
                <strong>Member Code:</strong> @membership.MemberCode<br />
                <strong>Plan Code:</strong> @membership.PlanCode<br />
                <strong>Start Date:</strong> @membership.StartDate.ToString("yyyy-MM-dd")<br />
                <strong>End Date:</strong> @membership.EndDate.ToString("yyyy-MM-dd")<br />
                <strong>Status:</strong> @membership.Status
            </p>
            <div class="alert alert-warning">
                Are you sure you want to delete this membership?
            </div>
            <EditForm Model="this" FormName="delete-membership-form" OnValidSubmit="ConfirmDelete">
                <button type="submit" class="btn btn-danger me-2" disabled="@isDeleting">
                    @if (isDeleting)
                    {
                        <span class="spinner-border spinner-border-sm me-1"></span>
                    }
                    Yes, Delete
                </button>
                <a class="btn btn-secondary" href="membership-list">Cancel</a>
            </EditForm>
        </div>
    </div>
}
