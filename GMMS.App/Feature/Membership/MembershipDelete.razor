@using MudBlazor

<MudDialog>
    <TitleContent>
        <MudText Typo="Typo.h6">
            <MudIcon Icon="@Icons.Material.Filled.Delete" Class="mr-3" Color="Color.Error" /> Delete Membership
        </MudText>
    </TitleContent>

    <DialogContent>
        @if (!string.IsNullOrEmpty(errorMessage))
        {
            <MudAlert Severity="Severity.Error" Class="mb-4">@errorMessage</MudAlert>
        }

        @if (isLoading)
        {
            <div class="d-flex justify-center pa-6">
                <MudProgressCircular Indeterminate="true" Size="Size.Large" />
            </div>
        }
        else if (membership is not null)
        {
            <MudText Typo="Typo.body1" Class="mb-2"><strong>Member:</strong> @membership.MemberName</MudText>
            <MudText Typo="Typo.body1" Class="mb-2"><strong>Plan:</strong> @membership.PlanName</MudText>
            <MudText Typo="Typo.body1" Class="mb-2"><strong>Start:</strong> @membership.StartDate.ToString("yyyy-MM-dd")</MudText>
            <MudText Typo="Typo.body1" Class="mb-2"><strong>End:</strong> @membership.EndDate.ToString("yyyy-MM-dd")</MudText>
            <MudText Typo="Typo.body1" Class="mb-4"><strong>Status:</strong> @membership.Status</MudText>

            <MudAlert Severity="Severity.Warning" Variant="Variant.Outlined">
                Are you sure you want to delete this membership?
            </MudAlert>
        }
    </DialogContent>

    <DialogActions>
        <MudButton OnClick="Cancel" Variant="Variant.Text">Cancel</MudButton>
        <MudButton OnClick="ConfirmDelete"
                   Variant="Variant.Filled"
                   Color="Color.Error"
                   Disabled="@isDeleting">
            @if (isDeleting)
            {
                <MudProgressCircular Size="Size.Small" Indeterminate="true" Class="mr-2" />
            }
            Yes, Delete
        </MudButton>
    </DialogActions>
</MudDialog>
