@page "/membership-list"

<h3>Membership List</h3>

@if (isLoading)
{
    <div class="d-flex justify-content-center">
        <div class="spinner-border" role="status">
            <span class="visually-hidden">Loading...</span>
        </div>
    </div>
}
else if (errorMessage is not null)
{
    <div class="alert alert-danger">@errorMessage</div>
}
else
{
    <div class="d-flex justify-content-between align-items-center mb-3">
        <span>Total: <strong>@totalCount</strong> memberships</span>
        <a class="btn btn-primary" href="membership-create?memberId=@MemberId">
            <i class="bi bi-plus-lg"></i> Create Membership
        </a>
    </div>

    @if (memberships is not null && memberships.Count > 0)
    {
        <div class="table-responsive">
            <table class="table table-striped table-hover">
                <thead class="table-dark">
                    <tr>
                        <th>#</th>
                        <th>Member Name</th>
                        <th>Plan Name</th>
                        <th>Start Date</th>
                        <th>End Date</th>
                        <th>Status</th>
                        <th>Actions</th>
                    </tr>
                </thead>
                <tbody>
                    @foreach (var m in memberships)
                    {
                        <tr>
                            <td>@m.MembershipId</td>
                            <td>@m.MemberName</td>
                            <td>@m.PlanName</td>
                            <td>@m.StartDate.ToString("yyyy-MM-dd")</td>
                            <td>@m.EndDate.ToString("yyyy-MM-dd")</td>
                            <td>@m.Status</td>
                            <td>
                                <a class="btn btn-sm btn-outline-primary me-1" href="membership-edit/@m.MembershipId?memberId=@MemberId">
                                    <i class="bi bi-pencil"></i>
                                </a>
                                <a class="btn btn-sm btn-outline-danger" href="membership-delete/@m.MembershipId?memberId=@MemberId">
                                    <i class="bi bi-trash"></i>
                                </a>
                            </td>
                        </tr>
                    }
                </tbody>
            </table>
        </div>
    }
    else
    {
        <div class="alert alert-info">No memberships found for this member.</div>
    }
}
