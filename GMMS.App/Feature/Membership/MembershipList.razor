@page "/membership-list"

<h3>
    @if (MemberId.HasValue)
    {
        <span>Member's Memberships</span>
    }
    else
    {
        <span>Membership List</span>
    }
</h3>

@if (MemberId.HasValue)
{
    <a class="btn btn-outline-secondary btn-sm mb-3" href="/member-list">
        <i class="bi bi-arrow-left"></i> Back to Members
    </a>
}

@if (isLoading)
{
    <div class="d-flex justify-content-center">
        <div class="spinner-border" role="status">
            <span class="visually-hidden">Loading...</span>
        </div>
    </div>
}
else if (errorMessage is not null)
{
    <div class="alert alert-danger">@errorMessage</div>
}
else if (memberships is null || memberships.Count == 0)
{
    <div class="alert alert-info">
        No memberships found.
        <a class="btn btn-primary btn-sm ms-3" href="membership-create">Create one</a>
    </div>
}
else
{
    <div class="d-flex justify-content-between align-items-center mb-3">
        <span>Total: <strong>@totalCount</strong> memberships</span>
        <a class="btn btn-primary" href="membership-create">
            <i class="bi bi-plus-lg"></i> Create Membership
        </a>
    </div>

    <div class="table-responsive">
        <table class="table table-striped table-hover">
            <thead class="table-dark">
                <tr>
                    <th scope="col">#</th>
                    <th scope="col">Member Code</th>
                    <th scope="col">Member Name</th>
                    <th scope="col">Plan Code</th>
                    <th scope="col">Plan Name</th>
                    <th scope="col">Start Date</th>
                    <th scope="col">End Date</th>
                    <th scope="col">Status</th>
                    <th scope="col">Actions</th>
                </tr>
            </thead>
            <tbody>
                @foreach (var m in memberships)
                {
                    <tr>
                        <td>@m.MembershipId</td>
                        <td>@m.MemberCode</td>
                        <td>@m.MemberName</td>
                        <td>@m.PlanCode</td>
                        <td>@m.PlanName</td>
                        <td>@m.StartDate.ToString("yyyy-MM-dd")</td>
                        <td>@m.EndDate.ToString("yyyy-MM-dd")</td>
                        <td>@m.Status</td>
                        <td>
                            <a class="btn btn-sm btn-outline-primary me-1" href="membership-edit/@m.MembershipId" title="Edit">
                                <i class="bi bi-pencil"></i>
                            </a>
                            <a class="btn btn-sm btn-outline-danger" href="membership-delete/@m.MembershipId" title="Delete">
                                <i class="bi bi-trash"></i>
                            </a>
                        </td>
                    </tr>
                }
            </tbody>
        </table>
    </div>

    <nav>
        <ul class="pagination justify-content-center">
            <li class="page-item @(pageNumber <= 1 ? "disabled" : "")">
                @if (pageNumber > 1)
                {
                    var prevUrl = MemberId.HasValue
                        ? $"/membership-list?memberId={MemberId}&page={pageNumber - 1}"
                        : $"/membership-list?page={pageNumber - 1}";
                    <a class="page-link" href="@prevUrl">Previous</a>
                }
                else
                {
                    <span class="page-link">Previous</span>
                }
            </li>
            <li class="page-item disabled">
                <span class="page-link">Page @pageNumber of @totalPages</span>
            </li>
            <li class="page-item @(pageNumber >= totalPages ? "disabled" : "")">
                @if (pageNumber < totalPages)
                {
                    var nextUrl = MemberId.HasValue
                        ? $"/membership-list?memberId={MemberId}&page={pageNumber + 1}"
                        : $"/membership-list?page={pageNumber + 1}";
                    <a class="page-link" href="@nextUrl">Next</a>
                }
                else
                {
                    <span class="page-link">Next</span>
                }
            </li>
        </ul>
    </nav>
}
