@page "/membership-create"

<h3>Create Membership</h3>

@if (!string.IsNullOrEmpty(errorMessage))
{
    <div class="alert alert-danger">@errorMessage</div>
}

@if (isLoadingData)
{
    <div class="d-flex justify-content-center">
        <div class="spinner-border" role="status">
            <span class="visually-hidden">Loading...</span>
        </div>
    </div>
}
else
{
    <div class="row">
        <div class="col-md-6">
            <EditForm Model="request" OnValidSubmit="Save">
                <div class="mb-3">
                    <label for="memberId" class="form-label">Member</label>
                    <select id="memberId" class="form-select" @bind-value="_memberIdStr" @bind-value:event="onchange">
                        <option value="">-- Select Member --</option>
                        @if (members is not null)
                        {
                            @foreach (var member in members)
                            {
                                <option value="@member.MemberId">@member.Name (@member.MemberCode)</option>
                            }
                        }
                    </select>
                </div>
                <div class="mb-3">
                    <label for="planId" class="form-label">Plan</label>
                    <select id="planId" class="form-select" @bind-value="_planIdStr" @bind-value:event="onchange">
                        <option value="">-- Select Plan --</option>
                        @if (plans is not null)
                        {
                            @foreach (var plan in plans)
                            {
                                <option value="@plan.MemberShipPlanId">@plan.PlanName</option>
                            }
                        }
                    </select>
                </div>
                <div class="mb-3">
                    <label for="paymentMethodId" class="form-label">Payment Method</label>
                    <select id="paymentMethodId" class="form-select" @bind-value="_paymentMethodIdStr" @bind-value:event="onchange">
                        <option value="">-- Select Payment Method --</option>
                        @if (paymentMethods is not null)
                        {
                            @foreach (var method in paymentMethods)
                            {
                                <option value="@method.PaymentMethodId">@method.Name</option>
                            }
                        }
                    </select>
                </div>
                <div class="mb-3">
                    <label for="amount" class="form-label">Amount</label>
                    <InputNumber id="amount" class="form-control" @bind-Value="request.Amount" />
                </div>
                <button type="submit" class="btn btn-primary" disabled="@isSaving">
                    @if (isSaving)
                    {
                        <span class="spinner-border spinner-border-sm me-1"></span>
                    }
                    Save
                </button>
                <a class="btn btn-secondary ms-2" href="member-list">Cancel</a>
            </EditForm>
        </div>
    </div>
}
